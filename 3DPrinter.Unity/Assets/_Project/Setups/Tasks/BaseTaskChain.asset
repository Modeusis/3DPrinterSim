  _steps:
  - <StepType>k__BackingField: 1
    <TaskText>k__BackingField: "\u041F\u043E\u0434\u043A\u043B\u044E\u0447\u0438\u0442\u0435
      \u043F\u0438\u0442\u0430\u043D\u0438\u0435 \u043F\u0440\u0438\u043D\u0442\u0435\u0440\u0430
