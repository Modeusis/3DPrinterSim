    _completeWhenAnyOfCompleted: 
  - <StepType>k__BackingField: 3
    <TaskText>k__BackingField: "\u041F\u043E\u0441\u0442\u0430\u0432\u044C\u0442\u0435
      \u0444\u0438\u043B\u0430\u043C\u0435\u043D\u0442 \u043D\u0430 \u043C\u0435\u0441\u0442\u043E,
      \u043A\u043B\u0438\u043A\u043D\u0443\u0432 \u043F\u043E \u043D\u0435\u043C\u0443"
    _completeWhenAnyOfCompleted: 
  - <StepType>k__BackingField: 4
    <TaskText>k__BackingField: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435
      \u043C\u043E\u0434\u0435\u043B\u044C \u043A\u043B\u0438\u043A\u043D\u0443\u0432
