    _completeWhenAnyOfCompleted: 
  - <StepType>k__BackingField: 2
    <TaskText>k__BackingField: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430
      \u043A\u043D\u043E\u043F\u043A\u0443 \u0432\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F,
