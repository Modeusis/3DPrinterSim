    _completeWhenAnyOfCompleted: 
  - <StepType>k__BackingField: 7
    <TaskText>k__BackingField: "\u041D\u0430\u0431\u043B\u044E\u0434\u0430\u0439\u0442\u0435
      \u0437\u0430 \u043F\u0440\u043E\u0446\u0435\u0441\u0441\u043E\u043C \u043F\u0435\u0447\u0430\u0442\u0438
