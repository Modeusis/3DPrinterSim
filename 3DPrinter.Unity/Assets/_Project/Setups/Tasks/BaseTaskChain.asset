      \u044D\u043A\u0440\u0430\u043D\u0435"
    _completeWhenAnyOfCompleted: 060000000700000008000000090000000a000000
  - <StepType>k__BackingField: 5
    <TaskText>k__BackingField: "\u0426\u0438\u043A\u043B\u0438\u0447\u043D\u043E
      \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0430\u0439\u0442\u0435 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u044C
      \u043C\u0435\u0436\u0434\u0443 Low, Medium, High"
    _completeWhenAnyOfCompleted: 060000000700000008000000090000000a000000
  - <StepType>k__BackingField: 6
    <TaskText>k__BackingField: "\u041D\u0430\u0447\u043D\u0438\u0442\u0435 \u043F\u0435\u0447\u0430\u0442\u044C
      \u043D\u0430\u0436\u0430\u0432 \u043A\u043D\u043E\u043F\u043A\u0443 \"\u041D\u0430\u0447\u0430\u0442\u044C
