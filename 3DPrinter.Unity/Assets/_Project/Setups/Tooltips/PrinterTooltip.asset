  m_Name: PrinterTooltip
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Scripts.Setups.Tooltip.TooltipData
  <Text>k__BackingField: "\u042D\u043A\u0441\u0442\u0440\u0443\u0434\u0435\u0440
    \u043F\u0440\u0438\u043D\u0442\u0435\u0440\u0430 \u2014 \u0435\u0433\u043E \u0433\u043B\u0430\u0432\u043D\u043E\u0435
    \u0440\u0430\u0431\u043E\u0447\u0435\u0435 \u043E\u0440\u0443\u0434\u0438\u0435.
    \u041E\u043D \u043D\u0430\u0433\u0440\u0435\u0432\u0430\u0435\u0442 \u043F\u043E\u0441\u0442\u0443\u043F\u0430\u044E\u0449\u0438\u0439
    \u043F\u043B\u0430\u0441\u0442\u0438\u043A \u0434\u043E \u0436\u0438\u0434\u043A\u043E\u0433\u043E
    \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u044F \u0438 \u0441 \u044E\u0432\u0435\u043B\u0438\u0440\u043D\u043E\u0439
    \u0442\u043E\u0447\u043D\u043E\u0441\u0442\u044C\u044E \u0432\u044B\u0434\u0430\u0432\u043B\u0438\u0432\u0430\u0435\u0442
    \u0435\u0433\u043E \u0441\u043B\u043E\u0439 \u0437\u0430 \u0441\u043B\u043E\u0435\u043C,
    \u043F\u043E\u0441\u0442\u0435\u043F\u0435\u043D\u043D\u043E \u0432\u044B\u0440\u0430\u0449\u0438\u0432\u0430\u044F
    \u043E\u0431\u044A\u0435\u043C\u043D\u0443\u044E \u0444\u0438\u0433\u0443\u0440\u0443
    \u043D\u0430 \u0441\u0442\u043E\u043B\u0435."
